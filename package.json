{
  "name": "mobilemaster",
  "version": "0.1.0",
  "private": true,
  "description": "MobileMaster — cross-platform Appium tests",
  "scripts": {
    "test:android": "cross-env PLATFORM=android wdio run ./wdio.conf.ts",
    "test:ios": "cross-env PLATFORM=ios wdio run ./wdio.conf.ts",
    "test:stub:android": "cross-env PLATFORM=android wdio run ./wdio.conf.ts --spec ./tests/app-launch.stub.ts",
    "test:stub:ios": "cross-env PLATFORM=ios wdio run ./wdio.conf.ts --spec ./tests/app-launch.stub.ts",
    "test:login": "cross-env PLATFORM=android wdio run ./wdio.conf.ts --spec ./tests/login.test.ts",
    "test:login:android": "cross-env PLATFORM=android wdio run ./wdio.conf.ts --spec ./tests/login.test.ts",
    "test:login:ios": "cross-env PLATFORM=ios wdio run ./wdio.conf.ts --spec ./tests/login.test.ts",
    "test:all": "npm run test:android && npm run test:ios",
    "test": "npm run test:android"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.14.1",
    "@wdio/appium-service": "^9.27.0",
    "@wdio/cli": "^9.12.4",
    "@wdio/globals": "^9.12.4",
    "@wdio/local-runner": "^9.12.4",
    "@wdio/mocha-framework": "^9.12.4",
    "@wdio/spec-reporter": "^9.12.4",
    "@wdio/types": "^9.12.4",
    "cross-env": "^7.0.3",
    "expect-webdriverio": "^5.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "webdriverio": "^9.27.0"
  },
  "dependencies": {
    "axios": "^1.8.4"
  }
}
